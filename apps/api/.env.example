# Database (Neon DB)
DB_HOST=your_db_host
DB_PORT=5432
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=your_db_name

# Server
PORT=3000

# Security (JWT, Encryption)
JWT_SECRET=your_jwt_secret_key
ENCRYPTION_KEY=your_encryption_key_32_bytes_hex

# Mail (Gmail for Admin Alerts)
GMAIL_USER=your_gmail_address
GMAIL_APP_PASSWORD=your_gmail_app_password

# Auth
NEON_AUTH_JWKS_URL=

# Admin
ADMIN_API_KEY=your_admin_api_key

# External API
DATA_GO_KR_API_KEY=your_data_go_kr_api_key
DATA_GO_KR_ENDPOINT=https://apis.data.go.kr/1471000/MdcinGrnIdntfcInfoService03/getMdcinGrnIdntfcInfoList03

# AI (Google Gemini SDK default env var)
GOOGLE_GENERATIVE_AI_API_KEY=your_gemini_api_key

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret