{
  "name": "pilly",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "ready": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\" && turbo run lint",
    "typecheck": "turbo run typecheck",
    "test:api": "cd apps/api && bun test",
    "test:web": "cd apps/web && bun test",
    "test": "turbo run test",
    "perf": "unlighthouse --site http://localhost:3000"
  },
  "devDependencies": {
    "@unlighthouse/cli": "^0.17.9",
    "prettier": "3.8.3",
    "turbo": "^2.9.8"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "packageManager": "bun@1.3.12",
  "overrides": {
    "dompurify": ">=3.4.2",
    "next": ">=16.2.4",
    "postcss": ">=8.5.13",
    "nodemailer": ">=8.0.7",
    "vite": ">=8.0.10",
    "hono": ">=4.12.16",
    "@hono/node-server": ">=2.0.1",
    "uuid": ">=14.0.0",
    "axios": ">=1.16.0",
    "langsmith": ">=0.6.0",
    "esbuild": ">=0.28.0",
    "protobufjs": ">=8.0.3",
    "fast-xml-parser": ">=5.7.2"
  }
}
