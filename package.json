{
  "name": "pilly",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "ready": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\" && turbo run lint",
    "typecheck": "turbo run typecheck",
    "test:api": "cd apps/api && bun test",
    "test:web": "cd apps/web && bun test",
    "test": "turbo run test",
    "perf": "unlighthouse --site http://localhost:3000"
  },
  "devDependencies": {
    "@unlighthouse/cli": "^0.17.9",
    "prettier": "3.8.1",
    "turbo": "^2.9.6"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "packageManager": "bun@1.3.12"
}
